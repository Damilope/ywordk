{
  "name": "ywordk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "next start -p $PORT",
    "build": "next build",
    "dev": "npx --yes -- softkave-forerunner@latest run-env -e .env.local --cmd \"next dev\"",
    "sync-public": "npx --yes -- softkave-forerunner@latest run-env --cmd \"zx sh/sync-public.mjs\"",
    "extract-matter-blogs": "npx --yes -- softkave-forerunner@latest run-env --cmd \"npx --yes -- tsx sh/extract-matter-blogs.ts\"",
    "lint": "next lint",
    "upload-source-maps": "npx --yes -- fimidx@latest source-maps upload --client-token \"$FIMIDX_SYMBOLICATION_AUTH_TOKEN\" --project-id \"$NEXT_PUBLIC_FIMIDX_LOGGER_PROJECT_ID\" --repo \"$NEXT_PUBLIC_FIMIDX_SYMBOLICATION_REPO\" --version \"$NEXT_PUBLIC_FIMIDX_SYMBOLICATION_VERSION\" --path .next",
    "delete-source-maps": "find .next -name '*.map' -type f -delete"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^1.16.8",
    "@mdx-js/loader": "^3.0.1",
    "@mdx-js/react": "^3.0.1",
    "@next/mdx": "^14.2.3",
    "@radix-ui/react-dialog": "^1.1.5",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.5",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@types/lodash-es": "^4.17.12",
    "@types/mdx": "^2.0.13",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "fimidara": "^1.37.4",
    "fimidx": "^0.7.0",
    "globby": "^14.0.2",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.436.0",
    "moment-timezone": "^0.5.46",
    "next": "14.2.35",
    "next-mdx-remote": "^5.0.0",
    "nextjs-toploader": "^3.7.15",
    "node-fetch": "^3.3.2",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^4.9.0",
    "rehype-highlight": "^7.0.1",
    "softkave-node-utils": "0.7.0",
    "swr": "^2.2.5",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "to-vfile": "^8.0.0",
    "vfile-matter": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "env-cmd": "^10.1.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "zx": "^8.1.5"
  }
